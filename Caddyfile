# Reverse proxy configuration.
# In local dev: use "localhost". In production: swap in your domain and Caddy
# handles HTTPS automatically via Let's Encrypt.

localhost {
	# API calls go to the backend over the internal network.
	handle /api/* {
		reverse_proxy backend:8000
	}

	# Everything else: React's static files (SPA).
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
