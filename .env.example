# Copy this file to .env and fill in the values. The real .env is NOT committed.

# --- Database (Supabase) ---
# Connection URL used by SQLAlchemy (psycopg 3 driver). Use Supabase's
# "Session pooler" connection string (Dashboard -> Connect -> Session pooler),
# NOT the transaction pooler (6543) or direct connection. Session mode is the
# only option that is IPv4-reachable on every tier AND supports prepared
# statements + Alembic DDL with no extra config.
#
# Format: postgresql+psycopg://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres?sslmode=require
#
# Note the username is the tenant-qualified form "postgres.<project-ref>",
# not plain "postgres". If the password contains special characters
# (%, @, :, /, etc.), they must be percent-encoded here (e.g. via Python's
# urllib.parse.quote), since this value is parsed as a URL.
DATABASE_URL=postgresql+psycopg://postgres.your-project-ref:change_this_to_a_strong_password@aws-your-region.pooler.supabase.com:5432/postgres?sslmode=require

# Environment: development | production
APP_ENV=development
