# Copy this file to .env and fill in the values. The real .env is NOT committed.

# --- PostgreSQL ---
POSTGRES_USER=cartera
POSTGRES_PASSWORD=change_this_to_a_strong_password
POSTGRES_DB=cartera

# --- Backend ---
# Connection URL used by SQLAlchemy. The "db" host is the service name
# in docker-compose (internal network). Do not change to localhost inside Docker.
DATABASE_URL=postgresql+psycopg://cartera:change_this_to_a_strong_password@db:5432/cartera

# Environment: development | production
APP_ENV=development
