# Copia este fichero a .env y rellena los valores. El .env real NO se commitea.

# --- PostgreSQL ---
POSTGRES_USER=cartera
POSTGRES_PASSWORD=cambia_esto_por_una_password_fuerte
POSTGRES_DB=cartera

# --- Backend ---
# URL de conexión que usa SQLAlchemy. El host "db" es el nombre del servicio
# en docker-compose (red interna). No cambiar a localhost dentro de Docker.
DATABASE_URL=postgresql+psycopg://cartera:cambia_esto_por_una_password_fuerte@db:5432/cartera

# Entorno: development | production
APP_ENV=development
